# Copy this file to `.env` (next to docker-compose.yml) and adjust for your host.
# Compose loads `.env` automatically; values override the defaults in docker-compose.yml.

# Comma-separated list of origins (URL schemes + host + port) the API will accept
# CORS requests from. The `Origin` header is the URL the user has in the address
# bar of the page that's making the request, NOT the user's IP.
#
# Examples:
#   SUZUME_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,http://192.168.1.50:4173
#   SUZUME_ALLOWED_ORIGINS=https://suzume.example.com
#   SUZUME_ALLOWED_ORIGINS=*    # allow any origin (only safe on a trusted LAN)
SUZUME_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,http://<your-lan-ip>:4173

# Where the client binds on the host. Use 0.0.0.0 to expose on the LAN, or a
# specific interface IP to restrict access.
# SUZUME_CLIENT_BIND_IP=0.0.0.0
# SUZUME_CLIENT_PORT=4173

# Backends reachable from the host (the server uses host networking).
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# ANKI_CONNECT_URL=http://127.0.0.1:8765

# RUST_LOG=info,tower_http=info
